# Copy to `.env` (gitignored) for local builds.
# PostHog project API keys are public client tokens (phc_…), not personal secrets.
#
# Injected at build time into:
#   - Native binary (posthog-rs) via app-tauri/build.rs
#   - Webview (posthog-js) via app-ui/build.rs → public/posthog-config.js
#
# CI: set the same vars as GitHub Actions secrets (see release.yml).

# Required for analytics in builds
POSTHOG_API_KEY=phc_your_project_api_key

# Optional — default is US cloud. Use EU if your project is there:
# POSTHOG_HOST=https://eu.i.posthog.com
# POSTHOG_HOST=https://us.i.posthog.com
