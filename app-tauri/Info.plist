<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- App Switcher (Cmd+Tab), Dock, Spotlight -->
  <key>CFBundleDisplayName</key>
  <string>CDXTheme</string>
  <!-- Menu bar app name + “About CDXTheme” -->
  <key>CFBundleName</key>
  <string>CDXTheme</string>
  <key>CFBundleGetInfoString</key>
  <string>CDXTheme</string>
  <key>NSHumanReadableCopyright</key>
  <string>Copyright © zeroventures. All rights reserved.</string>

  <!-- Minimum macOS version (12.0 = Monterey). Tauri also injects this from tauri.conf.json. -->
  <key>LSMinimumSystemVersion</key>
  <string>12.0</string>
</dict>
</plist>
